# ══════════════════════════════════════════════════════════════════════
# TCC — Transcript, Classify, Chat!
# ══════════════════════════════════════════════════════════════════════
# Copy this file to .env at the monorepo root and fill in your values.
# All paths are relative to the monorepo root unless absolute.

# ── Workspace ─────────────────────────────────────────────────────────
# WORKSPACES_DIR = directory containing all workspaces
# WORKSPACE      = active workspace name (subdirectory of WORKSPACES_DIR)
# Full path resolved as: WORKSPACES_DIR/WORKSPACE
# CLI flag --workspace=<name> overrides WORKSPACE per-command.

WORKSPACES_DIR=workspaces
WORKSPACE=noa

# ── API (LLM) ─────────────────────────────────────────────────────────
# Used by media pipeline commands (discover, classify, synthesize).
# Chat has its own overrides below (CHAT_API_*).
#
# Providers:
#   anthropic  → Anthropic direct (streaming + batch)
#   uptimize   → UPTIMIZE Foundry (OpenAI-compatible proxy, streaming only)

API_PROVIDER=anthropic
API_KEY=sk-ant-XXXXXXXXXX
API_MODEL=claude-sonnet-4-6-20250514
# API_BASE_URL=                           # Only needed for uptimize

# Media API mode: "streaming" (default) or "batch" (Anthropic only, -50% cost)
MEDIA_API_MODE=streaming

# ── Media processing ──────────────────────────────────────────────────
# Discover
MEDIA_DISCOVER_MAX_CHARS=400000           # Max chars sent to LLM per doc/section
MEDIA_DISCOVER_SECTION_MAX_CHARS=400000   # Max chars per TOC section
MEDIA_DISCOVER_MAX_TOKENS=1024            # Max tokens for LLM response

# Synthesize
MEDIA_SYNTHESIZE_MAX_TOKENS=16000         # Max tokens for SUMMARY.md / PLAN.md generation

# Classify
MEDIA_CLASSIFY_MAX_TOKENS=512             # Max tokens for classification response

# Split (RAG chunking)
MEDIA_SPLIT_MAX_CHUNK=6000                # Max chars per chunk (~1500 tokens)

# ── Embedding (media:embed) ──────────────────────────────────────────
# Engine: "nomic-local" (CPU, no API), "nomic-uptimize" (API), "jina-local" (CPU)
MEDIA_EMBED_ENGINE=nomic-local

# Quantization for local models: "q8" (fastest), "fp16" (recommended), "fp32" (best quality)
MEDIA_EMBED_DTYPE=fp16

# API credentials for nomic-uptimize (falls back to API_KEY/API_BASE_URL)
# MEDIA_EMBED_API_KEY=
# MEDIA_EMBED_API_BASE_URL=

# Batch processing
MEDIA_EMBED_BATCH_SIZE=10                 # Chunks per batch
MEDIA_EMBED_BATCH_CONCURRENCY=5           # Parallel batches (API only)

# ── Chat (RAG + LLM) ─────────────────────────────────────────────────
# Chat has its own LLM + embed config. Falls back to API_* / MEDIA_EMBED_*.
# This lets you use a faster model for chat while keeping a powerful one
# for the media pipeline.

# Chat LLM (fallback → API_*)
# CHAT_API_PROVIDER=anthropic
# CHAT_API_KEY=
# CHAT_API_BASE_URL=
# CHAT_API_MODEL=claude-sonnet-4-6-20250514
CHAT_API_STREAMING=true                   # Stream tokens from LLM (true) or wait for full response (false)

# Chat embedding (fallback → MEDIA_EMBED_*)
# ⚠️ Must produce vectors compatible with corpus embeddings in DB.
# CHAT_EMBED_ENGINE=nomic-local
# CHAT_EMBED_DTYPE=fp16

# Chat search
CHAT_TOP_K=25                             # Max chunks retrieved per query
CHAT_MIN_SCORE=0.3                        # Minimum cosine similarity (0.0–1.0)

# Deep Search: multi-pass retrieval with LLM-generated sub-queries
# Pass 1: normal embed → top-K. Pass 2: LLM generates 3-5 sub-queries
# → embed each → search → deduplicate → merge. Better for broad/synthesis
# questions. Adds ~3-5s latency (1 extra LLM call + sub-query embeddings).
CHAT_DEEP_SEARCH=false

# ── GPU pod (RunPod) ──────────────────────────────────────────────────
# Only needed for gpu:* and transcript:* commands.
# GPU_RUNPOD_API_KEY=                     # → https://www.runpod.io/console/user/settings
# GPU_RUNPOD_SSH_KEY=~/.ssh/runpod_ed25519
# GPU_RUNPOD_POD_NAME=tcc
# GPU_RUNPOD_TYPES=NVIDIA RTX PRO 4500,NVIDIA RTX A4000,NVIDIA L4,NVIDIA GeForce RTX 3090
# GPU_RUNPOD_DATACENTERS=EU-RO-1,EU-SE-1,EU-CZ-1,EU-NL-1
# GPU_RUNPOD_CLOUD_TYPE=SECURE
# GPU_RUNPOD_IMAGE=runpod/pytorch:1.0.2-cu1281-torch280-ubuntu2404

# ── Bundle export (Claude Projects) ──────────────────────────────────
# BUNDLE_MIN_QUALITY=medium               # Exclude docs below this quality (low/medium/high)
# BUNDLE_MAX_TOKENS=200000                # Warn if bundle exceeds this
