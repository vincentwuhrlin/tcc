# ═══════════════════════════════════════════════════════════════════
# TCC — Transcript, Classify & Chat!
# ═══════════════════════════════════════════════════════════════════
# Release 5 — Copy this file to .env and fill in your values.
#
# Fallback chains:
#   CHAT_API_*       → API_*
#   CHAT_EMBED_*     → MEDIA_EMBED_*
#   MEDIA_EMBED_API_*→ API_*
#
# You only need to set what differs from the defaults.


# ─── Workspace ────────────────────────────────────────────────────
# Directory containing all workspaces (relative to monorepo root)
WORKSPACES_DIR=workspaces

# Active workspace (subdirectory name inside WORKSPACES_DIR)
# Can be overridden per command: pnpm tcc chat --workspace=my-ws
WORKSPACE=industrial-edge

# Override individual paths (optional — defaults to {WORKSPACE}/media, etc.)
# MEDIA_DIR=
# CONTEXT_DIR=
# BUNDLES_DIR=


# ─── API — LLM for media pipeline ────────────────────────────────
# Used by: discover, classify, synthesize, split (TOC), embed:bench
# Provider: "anthropic" (direct) or "uptimize" (OpenAI-compatible proxy)
API_PROVIDER=uptimize
API_KEY=your-api-key-here
API_BASE_URL=https://api.nlp.p.uptimize.merckgroup.com
API_MODEL=eu.anthropic.claude-sonnet-4-6

# Batch mode (Anthropic direct only, -50% cost)
# "streaming" = one call at a time | "batch" = Anthropic Batch API
MEDIA_API_MODE=streaming


# ─── Media processing — fine-tuning ──────────────────────────────
# Most users don't need to change these.

# Discover
# MEDIA_DISCOVER_MAX_CHARS=400000
# MEDIA_DISCOVER_SECTION_MAX_CHARS=400000
# MEDIA_DISCOVER_MAX_TOKENS=1024

# Synthesize
# MEDIA_SYNTHESIZE_MAX_TOKENS=16000

# Classify
# MEDIA_CLASSIFY_MAX_TOKENS=512

# Split (RAG chunking)
# MEDIA_SPLIT_MAX_CHUNK=6000


# ─── Embedding — corpus (media:embed) ────────────────────────────
# Engine: "nomic-uptimize" (API) | "nomic-local" (ONNX CPU) | "jina-local" (ONNX CPU)
MEDIA_EMBED_ENGINE=nomic-local

# Quantization for local models: "q8" (fastest) | "fp16" (balanced) | "fp32" (best)
# Stored in model name in DB so different dtypes coexist.
MEDIA_EMBED_DTYPE=fp16

# Batch settings for corpus embedding
MEDIA_EMBED_BATCH_SIZE=5
MEDIA_EMBED_BATCH_CONCURRENCY=1

# API credentials for nomic-uptimize engine (fallback → API_KEY / API_BASE_URL)
# MEDIA_EMBED_API_KEY=
# MEDIA_EMBED_API_BASE_URL=


# ─── Chat — LLM ──────────────────────────────────────────────────
# Independent LLM config for interactive chat.
# All fallback to API_* — only set if you want different chat config.
# Example: use a cheaper/faster model for chat while keeping Sonnet for pipeline.

# CHAT_API_PROVIDER=uptimize          # fallback → API_PROVIDER
# CHAT_API_KEY=                       # fallback → API_KEY
# CHAT_API_BASE_URL=                  # fallback → API_BASE_URL
# CHAT_API_MODEL=                     # fallback → API_MODEL

# LLM streaming: server ↔ LLM API leg.
# true  = stream tokens (requires provider support, e.g. Anthropic direct)
# false = wait for full response, then forward via SSE
# The frontend ALWAYS uses SSE regardless of this setting.
CHAT_API_STREAMING=false


# ─── Chat — Embedding ────────────────────────────────────────────
# Embed engine for query embedding at chat time.
# All fallback to MEDIA_EMBED_* — only set if you want different chat embed config.
# ⚠️ Must produce vectors compatible with corpus embeddings in DB!

# CHAT_EMBED_ENGINE=                  # fallback → MEDIA_EMBED_ENGINE
# CHAT_EMBED_DTYPE=                   # fallback → MEDIA_EMBED_DTYPE
# CHAT_EMBED_API_KEY=                 # fallback → MEDIA_EMBED_API_KEY
# CHAT_EMBED_API_BASE_URL=            # fallback → MEDIA_EMBED_API_BASE_URL


# ─── Chat — Search ───────────────────────────────────────────────
# Number of chunks to retrieve per query
CHAT_TOP_K=30

# Minimum cosine similarity score (0.0–1.0). Chunks below this are excluded.
CHAT_MIN_SCORE=0.3


# ─── GPU pod (RunPod) ────────────────────────────────────────────
# Only needed for media:embed:gpu command (remote GPU embedding).

# GPU_RUNPOD_API_KEY=                 # → https://www.runpod.io/console/user/settings
# GPU_RUNPOD_SSH_KEY=~/.ssh/runpod_ed25519
# GPU_RUNPOD_POD_NAME=tcc
# GPU_RUNPOD_TYPES=NVIDIA RTX PRO 4500,NVIDIA RTX A4000,NVIDIA L4,NVIDIA GeForce RTX 3090
# GPU_RUNPOD_DATACENTERS=EU-RO-1,EU-SE-1,EU-CZ-1,EU-NL-1
# GPU_RUNPOD_CLOUD_TYPE=SECURE
# GPU_RUNPOD_IMAGE=runpod/pytorch:1.0.2-cu1281-torch280-ubuntu2404


# ─── Bundle (Claude Projects export) ─────────────────────────────
# BUNDLE_MIN_QUALITY=medium
# BUNDLE_MAX_TOKENS=200000


# ─── Web server ──────────────────────────────────────────────────
# PORT=3001
