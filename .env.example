# ══════════════════════════════════════════════════════════════════════
# tcc — Configuration
# ══════════════════════════════════════════════════════════════════════

# ── Workspace ────────────────────────────────────────────────────────
# WORKSPACES_DIR = directory containing all workspaces (relative to monorepo root)
# WORKSPACE      = active workspace name (subdirectory within WORKSPACES_DIR)
# Full path      = WORKSPACES_DIR/WORKSPACE
# Override per-run with: npm run media:discover -- --workspace=noa
WORKSPACES_DIR=workspaces
WORKSPACE=industrial-edge

# Advanced: override individual sub-paths with MEDIA_DIR, CONTEXT_DIR, BUNDLES_DIR

# ── GPU pod (RunPod) ────────────────────────────────────────────────
GPU_RUNPOD_API_KEY=rpa_XXXXXXXXXX
GPU_RUNPOD_POD_NAME=tcc
GPU_RUNPOD_SSH_KEY=~/.ssh/runpod_ed25519
GPU_RUNPOD_TYPES=NVIDIA RTX A4000,NVIDIA L4,NVIDIA GeForce RTX 3090
GPU_RUNPOD_DATACENTERS=EU-RO-1,EU-SE-1,EU-CZ-1,EU-NL-1
GPU_RUNPOD_CLOUD_TYPE=COMMUNITY           # SECURE | COMMUNITY (spot) | ALL

# ── Claude API ───────────────────────────────────────────────────────
# Switch between providers by changing these variables:
#
# For Anthropic direct:
#   API_PROVIDER=anthropic
#   API_KEY=sk-ant-XXXXXXXXXX
#   API_MODEL=claude-sonnet-4-6-20250514
#
# For UPTIMIZE Foundry (corporate):
#   API_PROVIDER=uptimize
#   API_BASE_URL=https://api.nlp.p.uptimize.merckgroup.com
#   API_KEY=YOUR_UPTIMIZE_TOKEN
#   API_MODEL=eu.anthropic.claude-sonnet-4-20250514-v1:0

API_PROVIDER=anthropic
API_KEY=sk-ant-XXXXXXXXXX
API_MODEL=claude-sonnet-4-6-20250514
# API_BASE_URL=                     # only needed for uptimize

# ── Media processing mode ────────────────────────────────────────────
MEDIA_API_MODE=streaming            # streaming | batch
                                    # streaming: 1 call per doc, real-time progress, works with all providers
                                    # batch: submit all at once, -50% cost, Anthropic provider only

# ── Media processing (discover) ────────────────────────────────────
MEDIA_DISCOVER_MAX_CHARS=400000          # chars — split large docs above this via TOC
MEDIA_DISCOVER_SECTION_MAX_CHARS=400000  # chars — max per TOC section after split
MEDIA_DISCOVER_MAX_TOKENS=1024           # max output tokens per discover call

# ── Media processing (synthesize) ──────────────────────────────────
MEDIA_SYNTHESIZE_MAX_TOKENS=16000     # max output tokens per synthesize call

# ── Media processing (classify) ────────────────────────────────────
MEDIA_CLASSIFY_MAX_TOKENS=512         # max output tokens per classify call

# ── Media tagging ────────────────────────────────────────────────────

# ── Media tagging ────────────────────────────────────────────────────
MEDIA_FILE_MODE=full                  # full | summary (head+mid+tail, cheaper)
MEDIA_SUMMARY_HEAD=2000               # chars from start   (summary mode only)
MEDIA_SUMMARY_MID=1500                # chars from middle  (summary mode only)
MEDIA_SUMMARY_TAIL=1000               # chars from end     (summary mode only)
# PLAN_FILE=../media/output/PLAN.md

# ── Media processing (split) ────────────────────────────────────────
MEDIA_SPLIT_THRESHOLD=200000              # chars (~50k tokens) — split docs above this
MEDIA_SPLIT_LEVEL=2                       # 1 = chapters (X), 2 = sections (X.Y)
MEDIA_SPLIT_MAX_CHUNK=100000              # chars (~25k tokens) — re-split chunks above this

# ── RAG — Embedding ────────────────────────────────────────────────
# Engine: nomic-uptimize | nomic-local | jina-local
RAG_ENGINE=nomic-uptimize

# RAG API credentials — independent from Claude API above.
# Falls back to API_KEY / API_BASE_URL if not set.
# This lets you use e.g. personal Anthropic for LLM + corporate UPTIMIZE for embed.
RAG_API_BASE_URL=https://api.nlp.p.uptimize.merckgroup.com
RAG_API_KEY=YOUR_UPTIMIZE_TOKEN
# RAG_API_KEY=                            # omit to reuse API_KEY
# RAG_API_BASE_URL=                       # omit to reuse API_BASE_URL

RAG_BATCH_SIZE=10                         # chunks per batch (lower if rate-limited)
RAG_BATCH_CONCURRENCY=5                         # parallel API requests (ignored for local engines)

# ── RAG — Search ───────────────────────────────────────────────────
RAG_TOP_K=20                              # chunks returned per query

# ── Projects (Claude Projects export) ────────────────────────────────
BUNDLE_MIN_QUALITY=medium         # low | medium | high — exclude docs below this
BUNDLE_MAX_TOKENS=200000          # max tokens per bundle
# PROJECTS_FILE=../projects/projects.json
