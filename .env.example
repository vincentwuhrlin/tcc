# ═══════════════════════════════════════════════════════════════════
# TCC — Transcript, Classify & Chat!
# ═══════════════════════════════════════════════════════════════════
# Release 6 — Copy this file to .env and fill in your values.
#
# Fallback chains:
#   CHAT_API_*       → API_*
#   CHAT_EMBED_*     → MEDIA_EMBED_*
#   MEDIA_EMBED_API_*→ API_*
#
# You only need to set what differs from the defaults.


# ─── Workspace ────────────────────────────────────────────────────
# Directory containing all workspaces (relative to monorepo root)
WORKSPACES_DIR=workspaces

# Active workspace (subdirectory name inside WORKSPACES_DIR)
# Can be overridden per command: pnpm tcc chat --workspace=my-ws
WORKSPACE=noa

# Override individual paths (optional — defaults to {WORKSPACE}/media, etc.)
# MEDIA_DIR=
# CONTEXT_DIR=
# BUNDLES_DIR=


# ─── API — LLM for media pipeline ────────────────────────────────
# Used by: discover, classify, synthesize, split (TOC), embed:bench
# Provider: "anthropic" (direct) or "uptimize" (OpenAI-compatible proxy)
API_PROVIDER=uptimize
API_KEY=your-api-key-here
API_BASE_URL=https://api.nlp.p.uptimize.merckgroup.com
API_MODEL=eu.anthropic.claude-sonnet-4-6

# Batch mode (Anthropic direct only, -50% cost)
# "streaming" = one call at a time | "batch" = Anthropic Batch API
MEDIA_API_MODE=streaming


# ─── Media processing — fine-tuning ──────────────────────────────
# Most users don't need to change these.

# Discover
# MEDIA_DISCOVER_MAX_CHARS=400000
# MEDIA_DISCOVER_SECTION_MAX_CHARS=400000
# MEDIA_DISCOVER_MAX_TOKENS=1024

# Synthesize
# MEDIA_SYNTHESIZE_MAX_TOKENS=16000

# Classify
# MEDIA_CLASSIFY_MAX_TOKENS=512

# Split (RAG chunking)
# MEDIA_SPLIT_MAX_CHUNK=6000


# ─── Embedding — corpus (media:embed) ────────────────────────────
# Engine: "nomic-uptimize" (API) | "nomic-local" (ONNX CPU) | "jina-local" (ONNX CPU)
MEDIA_EMBED_ENGINE=nomic-local

# Quantization for local models: "q8" (fastest) | "fp16" (balanced) | "fp32" (best)
# Stored in model name in DB so different dtypes coexist.
MEDIA_EMBED_DTYPE=fp16

# Batch settings for corpus embedding
MEDIA_EMBED_BATCH_SIZE=5
MEDIA_EMBED_BATCH_CONCURRENCY=1

# API credentials for nomic-uptimize engine (fallback → API_KEY / API_BASE_URL)
# MEDIA_EMBED_API_KEY=
# MEDIA_EMBED_API_BASE_URL=


# ─── Chat — LLM ──────────────────────────────────────────────────
# Independent LLM config for interactive chat.
# All fallback to API_* — only set if you want different chat config.
# Example: use a cheaper/faster model for chat while keeping Sonnet for pipeline.

# CHAT_API_PROVIDER=uptimize          # fallback → API_PROVIDER
# CHAT_API_KEY=                       # fallback → API_KEY
# CHAT_API_BASE_URL=                  # fallback → API_BASE_URL
# CHAT_API_MODEL=                     # fallback → API_MODEL

# LLM streaming: server ↔ LLM API leg.
# true  = stream tokens (requires provider support, e.g. Anthropic direct)
# false = wait for full response, then forward via SSE
# The frontend ALWAYS uses SSE regardless of this setting.
CHAT_API_STREAMING=false


# ─── Chat — Embedding ────────────────────────────────────────────
# Embed engine for query embedding at chat time.
# Used for both RAG search AND semantic history search.
# All fallback to MEDIA_EMBED_* — only set if you want different chat embed config.
# ⚠️ Must produce vectors compatible with corpus embeddings in DB!

# CHAT_EMBED_ENGINE=                  # fallback → MEDIA_EMBED_ENGINE
# CHAT_EMBED_DTYPE=                   # fallback → MEDIA_EMBED_DTYPE
# CHAT_EMBED_API_KEY=                 # fallback → MEDIA_EMBED_API_KEY
# CHAT_EMBED_API_BASE_URL=            # fallback → MEDIA_EMBED_API_BASE_URL


# ─── Chat — Search ───────────────────────────────────────────────
# Number of chunks to retrieve per query
CHAT_TOP_K=30

# Minimum cosine similarity score (0.0–1.0). Chunks below this are excluded.
CHAT_MIN_SCORE=0.3

# Deep Search — multi-pass retrieval. Pass 1 does a normal RAG search,
# then the LLM generates 3–5 sub-queries which are each embedded and searched,
# results deduplicated and merged. Closes the gap with Claude Projects on
# broad synthesis questions. Costs 1 extra LLM call per query.
CHAT_DEEP_SEARCH=true


# ─── Chat — Focus mode ───────────────────────────────────────────
# When the user clicks a category pill after a response, load ALL chunks
# from that category (up to this token budget) and re-run the LLM with
# exhaustive context. ~4 chars per token, so 150000 tokens ≈ 600k chars.
CHAT_FOCUS_MAX_TOKENS=150000


# ─── Chat — Compaction (session history summarization) ──────────
# When total session history exceeds THRESHOLD_TOKENS, older messages
# are summarized into a structured 5-section Markdown summary. Rolling
# compaction: the existing summary is merged with new messages on each
# re-compact, so context never grows unbounded.
#
# Note: these vars only control the WITHIN-SESSION compaction of the
# current chat. They do NOT affect cross-session memories (Settings
# UI) or semantic history search (always on).
#
# ┌────────────────────────────────────────────────────────────────────┐
# │  THREE RECOMMENDED PROFILES                                        │
# ├────────────────────────────────────────────────────────────────────┤
# │                                                                    │
# │  CONSERVATIVE (safe for any model, incl. 32k context)              │
# │    CHAT_COMPACTION_THRESHOLD_TOKENS=20000                          │
# │    CHAT_COMPACTION_WINDOW_TOKENS=8000                              │
# │    CHAT_COMPACTION_SUMMARY_TOKENS=2000                             │
# │    Compacts often, keeps recent ~20 exchanges verbatim.            │
# │                                                                    │
# │  BALANCED (recommended for Claude 200k)                            │
# │    CHAT_COMPACTION_THRESHOLD_TOKENS=60000                          │
# │    CHAT_COMPACTION_WINDOW_TOKENS=24000                             │
# │    CHAT_COMPACTION_SUMMARY_TOKENS=4000                             │
# │    Rare compactions, keeps ~60 exchanges verbatim.                 │
# │                                                                    │
# │  AGGRESSIVE (max fidelity, higher per-call cost)                   │
# │    CHAT_COMPACTION_THRESHOLD_TOKENS=120000                         │
# │    CHAT_COMPACTION_WINDOW_TOKENS=60000                             │
# │    CHAT_COMPACTION_SUMMARY_TOKENS=6000                             │
# │    Very rare compactions, keeps ~150 exchanges verbatim.           │
# │    Costs ~2x per call vs balanced but near-perfect recall.         │
# │                                                                    │
# └────────────────────────────────────────────────────────────────────┘
#
# Trade-off: the WINDOW is the verbatim part (lossless). The SUMMARY
# is a structured compression of everything older. Bigger window =
# better fidelity but more tokens per call. Rarer compactions = less
# quality loss over time (each compaction is a lossy pass).

CHAT_COMPACTION_THRESHOLD_TOKENS=20000
CHAT_COMPACTION_WINDOW_TOKENS=8000
CHAT_COMPACTION_SUMMARY_TOKENS=2000


# ─── Chat — Memories (cross-session facts) ───────────────────────
# After each compaction, durable facts about the user are automatically
# extracted (role, projects, preferences, collaborators…) and injected
# into every future chat in the workspace.
#
# No env vars — fully controlled at runtime via Settings → Memories:
#   • Master toggle per workspace (on by default)
#   • Per-memory enable/disable switch
#   • Manual extraction via the 🧠 Memories button in the chat footer
#
# Scope: workspace-local (stored in workspace.db)


# ─── Chat — Semantic history search ──────────────────────────────
# Every chat message ≥ 30 chars is embedded at save time (fire-and-forget)
# and indexed in-memory at boot. Search via the sidebar search bar or
# Ctrl+K, results grouped by session with cosine similarity scores.
#
# No env vars — the feature is always on.
#
# For existing workspaces with prior conversations, backfill the index:
#
#   curl -X POST http://localhost:3001/api/history/backfill
#
# (~1-2 min per 1000 messages with nomic-local fp16)
#
# Stats endpoint: GET /api/history/stats
#   → { totalMessages, embeddedMessages, indexed }


# ─── GPU pod (RunPod) ────────────────────────────────────────────
# Only needed for media:embed:gpu command (remote GPU embedding).

# GPU_RUNPOD_API_KEY=                 # → https://www.runpod.io/console/user/settings
# GPU_RUNPOD_SSH_KEY=~/.ssh/runpod_ed25519
# GPU_RUNPOD_POD_NAME=tcc
# GPU_RUNPOD_TYPES=NVIDIA RTX PRO 4500,NVIDIA RTX A4000,NVIDIA L4,NVIDIA GeForce RTX 3090
# GPU_RUNPOD_DATACENTERS=EU-RO-1,EU-SE-1,EU-CZ-1,EU-NL-1
# GPU_RUNPOD_CLOUD_TYPE=SECURE
# GPU_RUNPOD_IMAGE=runpod/pytorch:1.0.2-cu1281-torch280-ubuntu2404


# ─── Bundle (Claude Projects export) ─────────────────────────────
# BUNDLE_MIN_QUALITY=medium
# BUNDLE_MAX_TOKENS=200000


# ─── Web server ──────────────────────────────────────────────────
# Host and ports for the TCC web UI.
#
# TCC runs two servers:
#   1. UI server (Vite)  — this is what you open in your browser
#   2. API server (Hono) — internal, the UI talks to it for /api/*
#
# Default setup opens at http://localhost:3000

# Host to bind to. Use "localhost" to only accept connections from this
# machine (safest, default). Use "0.0.0.0" to expose on your LAN so
# colleagues on the same network can open it from their own browser.
HOST=localhost

# User-facing port — what you type in your browser after "http://host:"
WEB_PORT=3000

# Internal API port — you don't need to change this unless 3001 is taken
API_PORT=3001
