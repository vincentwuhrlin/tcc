# ══════════════════════════════════════════════════════════════════════
# TCC — Quick start config
# ══════════════════════════════════════════════════════════════════════
# Copy this file to .env and fill in your API key.
# For the full list of tunable options, see .env.example.

# ── Web server ──────────────────────────────────────────────────────
# Open the UI at http://<HOST>:<WEB_PORT> after running `pnpm run chat`
HOST=localhost
WEB_PORT=3000
API_PORT=3001

# ── Workspace ───────────────────────────────────────────────────────
# WORKSPACES_DIR = directory containing all workspaces
# WORKSPACE      = name of the active workspace (subdirectory)
WORKSPACES_DIR=workspaces
WORKSPACE=noa

# ── LLM API ─────────────────────────────────────────────────────────
# Option A — UPTIMIZE Foundry (Merck corporate proxy, default)
API_PROVIDER=uptimize
API_BASE_URL=https://api.nlp.p.uptimize.merckgroup.com
API_KEY=<YOUR_UPTIMIZE_API_KEY>
API_MODEL=eu.anthropic.claude-sonnet-4-6

# Option B — Anthropic direct (uncomment and comment Option A above)
# API_PROVIDER=anthropic
# API_KEY=sk-ant-XXXXXXXXXXXX
# API_MODEL=claude-sonnet-4-6

# ── Embeddings ──────────────────────────────────────────────────────
# nomic-local = ONNX CPU, no API calls, downloads ~274 MB on first run
MEDIA_EMBED_ENGINE=nomic-local
MEDIA_EMBED_DTYPE=fp16

# ── Chat tuning — aggressive profile (max quality) ──────────────────
# See .env.example for the balanced and conservative profiles.
CHAT_TOP_K=50
CHAT_MIN_SCORE=0.25
CHAT_DEEP_SEARCH=true
CHAT_FOCUS_MAX_TOKENS=150000
CHAT_COMPACTION_THRESHOLD_TOKENS=120000
CHAT_COMPACTION_WINDOW_TOKENS=60000
CHAT_COMPACTION_SUMMARY_TOKENS=6000
