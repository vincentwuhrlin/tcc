# ══════════════════════════════════════════════════════════════════════
# tcc — Configuration
# ══════════════════════════════════════════════════════════════════════

# ── Workspace ────────────────────────────────────────────────────────
# Single directory containing media/, context/, projects/ subdirectories.
# Override per-run with: npm run media:discover -- --workspace=../workspaces/noa
WORKSPACES=workspaces
WORKSPACE=industrial-edge

# ── GPU pod (RunPod) ────────────────────────────────────────────────
GPU_RUNPOD_API_KEY=xxx
GPU_RUNPOD_SSH_KEY=~/.ssh/runpod_ed25519
GPU_RUNPOD_IMAGE=runpod/pytorch:1.0.2-cu1281-torch280-ubuntu2404
GPU_RUNPOD_TYPES=NVIDIA RTX PRO 6000 Blackwell Server Edition
GPU_RUNPOD_DATACENTERS=EU-RO-1,EU-SE-1,EU-CZ-1,EU-NL-1
GPU_RUNPOD_CLOUD_TYPE=COMMUNITY     # SECURE | COMMUNITY (spot) | ALL
GPU_RUNPOD_POD_NAME=tcc

# ── Claude API : Anthropic direct ────────────────────────────────────
# API_PROVIDER=anthropic
# API_KEY=sk-ant-XXXXXXXXXX
# API_MODEL=claude-sonnet-4-6

# ── Claude API : UPTIMIZE Foundry (corporate ─────────────────────────
API_PROVIDER=uptimize
API_BASE_URL=https://api.nlp.p.uptimize.merckgroup.com
API_KEY=071ee7f2-d95d-4bfb-a5e4-7d81bd83eff6
API_MODEL=eu.anthropic.claude-sonnet-4-6

# ── Media AI API processing mode ────────────────────────────────────────────
MEDIA_API_MODE=streaming            # streaming | batch
                                    # streaming: 1 call per doc, real-time progress, works with all providers
                                    # batch: submit all at once, -50% cost, Anthropic provider only

# ── Media processing (discover) ────────────────────────────────────
MEDIA_DISCOVER_MAX_CHARS=400000             # split large docs above this via TOC
MEDIA_DISCOVER_SECTION_MAX_CHARS=400000     # max per TOC section after split
MEDIA_DISCOVER_MAX_TOKENS=1024              # max output tokens per discover call

# ── Media processing (synthesize) ──────────────────────────────────
MEDIA_SYNTHESIZE_MAX_TOKENS=16000     # max output tokens per synthesize call

# ── Media processing (classify) ────────────────────────────────────
MEDIA_CLASSIFY_MAX_TOKENS=512         # max output tokens per classify call

# ── Media processing (split) ──────────────────────────────────────
MEDIA_SPLIT_MAX_CHUNK=100000          # chars (~25k tokens) — re-split chunks above this

# ── Projects (Claude Projects export) ────────────────────────────────
BUNDLE_MIN_QUALITY=medium             # low | medium | high — exclude docs below this
BUNDLE_MAX_TOKENS=200000              # max tokens per bundle

#
