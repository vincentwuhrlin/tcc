##MEDIA_SPLIT_LEVEL=4                       # 1 = chapters (X), 2 = sections (X.Y)
##MEDIA_SPLIT_MAX_CHUNK=100000              # chars (~25k tokens) — re-split chunks above this
#
#MEDIA_SPLIT_MAX_CHUNK=6000                # chars (~1500 tokens) — max chunk size for RAG
